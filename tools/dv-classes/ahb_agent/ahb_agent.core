name: "lowrisc:dv:ahb_agent:0.1"
description: "AHB agent"
filesets:
  files_dv:
    depend:
      - lowrisc:dv:dv_utils
    files:
      - ahb_if.sv
      - ahb_agent_pkg.sv

      - ahb_status_item.svh: {is_include_file: true}
      - ahb_txn_request_item.svh: {is_include_file: true}
      - ahb_txn_response_item.svh: {is_include_file: true}

      - ahb_mgr_driver.svh: {is_include_file: true}

      - seq_lib/ahb_transfer_seq.svh: {is_include_file: true}

    file_type: systemVerilogSource

targets:
  default:
    filesets:
      - files_dv
